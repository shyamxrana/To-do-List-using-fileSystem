
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <title>Document</title>
  </head>
  <body>
    <div class="main w-full min-h-screen bg-zinc-900 text-center">
      <div class="form p-10 text-white">
      <h1 class="text-8xl">Just do it.</h1>
        <form action="/create" method="POST" class="mt-10 ml-100">
          <input
            class="block w-100 rounded-md outline-none px-5 py-2 bg-zinc-700"
            type="text"
            placeholder="Title goes here..."
            name="title"
          />
          <textarea
            class="block w-100 rounded-md outline-none px-5 mt-2 py-2 bg-zinc-700 resize-none"
            placeholder="Write your task here..."
            name="details"
          ></textarea>
          <input
            class="mt-5 bg-blue-600 px-5 py-2 rounded-md cursor-pointer -ml-97"
            type="submit"
            value="Create task"
          />
        </form>
      </div>
      <div class="tasks flex flex-wrap gap-3 p-8">
        <% if(files.length > 0) { %> <% files.forEach(function(val) { %>
        <div class="task min-w-72 px-3 py-4 rounded-md bg-zinc-700">
          <h1 class="text-2xl text-white tracking-tighter"><%= val %></h1>
          <div class="flex w-full justify-between items-center mt-3" >
            <a class="text-blue-500 inline-block" href="/files/<%= val %>"
              >Read more.</a
            >
            <a class="text-zinc-400" href="/edit/<%= val %>"
              >Edit Filename</a
            >
          </div>
        </div>
        <% }) %> <% } else { %>
        <h3 class="text-zinc-500 ml-140 border p-3">No task yet.</h3>
        <% } %>
      </div>
    </div>

    <script src="/javascripts/scripts.js"></script>
  </body>
</html>
