<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <title>Document</title>
  </head>
  <body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
      <a class="text-blue-500 inline-block mb-10" href="/">Go Back to Home</a>
      <div class="text-center flex flex-col gap-4">
        <h1 class="text-5xl">Edit name</h1>
        <form action="/edit" method="POST" class="mt-5 ml-100">
          <input
            class="block w-1/2 rounded-md outline-none px-5 py-3 bg-zinc-700 text-zinc-500"
            type="text"
            placeholder="Previous Name goes here..."
            name="previous"
            value="<%= filesname %>"
          />
          <input class="block w-1/2 rounded-md outline-none px-5 py-3
          bg-zinc-700 mt-2 type="text" placeholder="New Name..." name="new" />

          <input
            class="mt-5 bg-yellow-600 px-5 py-2 rounded-md cursor-pointer -ml-97"
            type="submit"
            value="Update task"
          />
        </form>
      </div>
    </div>

    <script src="/javascripts/scripts.js"></script>
  </body>
</html>
